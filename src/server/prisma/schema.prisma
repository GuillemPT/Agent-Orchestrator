// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── User & Auth ───────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts   Account[]
  sessions   Session[]
  projects   Project[]
  gitTokens  GitToken[]
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String   // "oauth"
  provider          String   // "github" | "google"
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Domain Entities ───────────────────────────────────────────────────────────

model Project {
  id        String    @id @default(cuid())
  userId    String
  name      String
  repoUrl   String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  agents Agent[]
  skills Skill[]
  mcps   MCP[]

  @@index([userId])
}

model Agent {
  id        String   @id @default(cuid())
  projectId String
  name      String
  version   String   @default("1.0.0")
  content   String   // JSON blob with full agent data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions AgentVersion[]

  @@index([projectId])
}

model AgentVersion {
  id        String   @id @default(cuid())
  agentId   String
  content   String   // JSON blob snapshot
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

model Skill {
  id        String   @id @default(cuid())
  projectId String
  name      String
  content   String   // JSON blob with full skill data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model MCP {
  id        String   @id @default(cuid())
  projectId String
  label     String
  config    String   // JSON blob with MCP servers config
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ── Git Provider Tokens (encrypted) ───────────────────────────────────────────

model GitToken {
  id        String   @id @default(cuid())
  userId    String
  provider  String   // "github" | "gitlab" | "bitbucket"
  token     String   // AES-256 encrypted access token
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}
